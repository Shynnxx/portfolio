---
interface Project {
  title: string;
  description: string;
  tags: string[];
  color: string;
  link: string;
  linkLabel?: string;
}

const projects: Project[] = [
  {
    title: 'RogueFactory',
    description:
      'A procedurally-generated roguelike factory builder. Automate production lines, survive waves of enemies, and descend deeper into the dungeon. Built in Unity with a custom dungeon generation system.',
    tags: ['Unity', 'C#', 'Roguelike', 'Procedural Gen'],
    color: '#1a2a1a',
    link: 'https://github.com/Shynnxx/RogueFactory',
    linkLabel: 'View on GitHub',
  },
  {
    title: 'DungeonCrawl',
    description:
      'A classic top-down dungeon crawler with turn-based combat, randomized loot, and permadeath. Features a hand-crafted pixel art style and emergent gameplay through item synergies.',
    tags: ['Godot', 'GDScript', 'Turn-Based', 'Pixel Art'],
    color: '#1a1a2e',
    link: '#',
    linkLabel: 'Coming Soon',
  },
  {
    title: 'Ludum Dare #55 Entry',
    description:
      'A 48-hour game jam entry. A minimalist puzzle platformer where you summon echoes of your past movement to solve increasingly complex spatial challenges.',
    tags: ['Unity', 'C#', 'Game Jam', 'Puzzle'],
    color: '#1e1a2e',
    link: '#',
    linkLabel: 'Play on itch.io',
  },
];
---

<section id="projects">
  <div class="container">
    <h2 class="section-title">My <span>Projects</span></h2>
    <div class="section-divider"></div>

    <div class="grid">
      {projects.map((project) => (
        <article class="card">
          <div class="card-thumb" style={`background: ${project.color};`} aria-hidden="true">
            <span class="card-thumb-label">{project.title}</span>
          </div>
          <div class="card-body">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <a
              class="card-link"
              href={project.link}
              target={project.link !== '#' ? '_blank' : undefined}
              rel={project.link !== '#' ? 'noopener' : undefined}
            >
              {project.linkLabel ?? 'View Project'} →
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  #projects {
    background: linear-gradient(to bottom, var(--bg), #0a0d12, var(--bg));
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) * 1.5);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 229, 255, 0.3);
    box-shadow: 0 12px 40px rgba(0, 229, 255, 0.05);
  }

  .card-thumb {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .card-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(255,255,255,0.015) 0px,
      rgba(255,255,255,0.015) 1px,
      transparent 1px,
      transparent 20px
    );
  }

  .card-thumb-label {
    font-size: 1.5rem;
    font-weight: 700;
    color: rgba(255,255,255,0.15);
    letter-spacing: -0.02em;
    font-family: var(--font-mono);
    z-index: 1;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .card-body p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.15);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    transition: gap 0.2s;
    display: inline-block;
    margin-top: 0.25rem;
  }
  .card-link:hover {
    text-decoration: none;
    color: var(--accent-dim);
  }
</style>
