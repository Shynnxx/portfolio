---
interface Project {
  id: string;
  title: string;
  description: string;
  details: string;
  tags: string[];
  color: string;
  link: string;
  linkLabel?: string;
}

const projects: Project[] = [
  {
    id: 'roguefactory',
    title: 'RogueFactory',
    description:
      'Rogue Factory is a run-based action roguelike / factory automation hybrid in which combat and production do not exist as separate layers, but actively drive one another. The core vision is to create a game where the player\'s build identity is shaped not only by abstract upgrade choices, but also by the physical structure of the production network they create during the run.',
    details:
      'You build your factory layout as part of each run and then defend it in direct combat. Resource flow, machine placement, and combat choices all affect one another, which creates a different strategic profile every run. The game is currently in early development and I\'m building the core systems and prototyping the first level to explore the design space. Below you can see a prototype building system I added, allowing the player to build conveyor belts from certain locations (i.e. resource nodes) and then snap them to another allowed location.',
    tags: ['UE5', 'C++', 'Roguelike', 'Automation', 'Personal', '2026-Present'],
    color: '#1a2a1a',
    link: '#',
    linkLabel: 'In Development',
  },
  {
    id: 'td-game-prototype',
    title: 'TD Game Prototype',
    description:
      'This project was part of my bachelor thesis (Game Development Workflow with AI), where I used AI tools and analyzed/evaluated them to create a prototype level for a simple tower defense game.',
    details:
      'Below is a snippet of the prototype level with simple mechanics like "start wave" and "buy upgrades for your tower":',
    tags: ['UE5', 'C++', 'AI', 'Tower Defense', 'Personal', '2025'],
    color: '#1a1a2e',
    link: '#',
    linkLabel: 'Finished',
  },
  {
    id: 'predecessor',
    title: 'Predecessor',
    description:
      'Predecessor is a free-to-play third-person MOBA developed by Omeda Studios, available on PC, PlayStation and Xbox. Unlike traditional top-down MOBAs, it puts you directly behind your hero in full 3D. Choose from a diverse roster of heroes, master unique abilities, and compete in 5v5 matches with cross-play support across all platforms.',
    details:
      'As a Technical Designer in a small engineering team, I had to wear many hats, shifting my focus across the entire project wherever I was needed most. Here are a couple examples of systems and features I worked on during development:',
    tags: ['UE 5', 'C++', 'MOBA', 'Third-Person', 'Competitive', 'Professional', '2022-2025'],
    color: '#1e1a2e',
    link: '#',
    linkLabel: 'Play on itch.io',
  },
];
---

<section id="projects">
  <div class="container">
    <h2 class="section-title">My <span>Projects</span></h2>
    <div class="section-divider"></div>

    <div class="grid">
      {projects.map((project) => (
        <article class="card" id={`project-card-${project.id}`}>
          <div class="card-thumb" style={`background: ${project.color};`} aria-hidden="true">
            <span class="card-thumb-label">{project.title}</span>
          </div>
          <div class="card-body">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <a class="card-link" href={`#project-${project.id}`}>View details ↓</a>
          </div>
        </article>
      ))}
    </div>

    <div class="project-details">
      {projects.map((project) => (
        <article class="project-detail" id={`project-${project.id}`}>
          <h3>{project.title}</h3>
          <p>{project.details}</p>
          {project.id === 'roguefactory' && (
            <div class="video-embed">
              <video autoplay loop muted playsinline>
                <source src="/portfolio/RogueFactory.mp4" type="video/mp4" />
              </video>
            </div>
          )}
          {project.id === 'td-game-prototype' && (
            <div class="video-embed">
              <video autoplay loop muted playsinline>
                <source src="/portfolio/TDGameSnippet.mp4" type="video/mp4" />
              </video>
            </div>
          )}
          {project.id === 'predecessor' && (
            <>
              <h4 class="detail-subtitle">Brawl</h4>
              <p class="detail-subtitle-text">
                Predecessor's first new game mode, where I owned the gameplay side of development,
                implementing core systems like the points system, adjusting monsters and minions and
                creating C++/Blueprint functions to adjust heroes and items specifically for the game mode:
              </p>
              <div class="video-embed">
                <iframe
                  src="https://www.youtube.com/embed/cAQCGO2-Dm4?si=yW0u4ICGKoGtnI_F"
                  title="YouTube video player"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>

              <h4 class="detail-subtitle">Teleporters</h4>
              <p class="detail-subtitle-text">
                I implemented a way for heroes to traverse the map quickly in a cinematic way.
              </p>
              <div class="video-embed">
                <iframe
                  src="https://www.youtube.com/embed/EUOFU92W2wU?si=Bi3WksX9H43H1gIb&start=2693"
                  title="YouTube video player"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>

              <h4 class="detail-subtitle">Augments</h4>
              <p class="detail-subtitle-text">
                Augments altered every single hero in the game significantly. I created the framework for
                them to work as well as implementing and designing many of them.
              </p>
              <div class="video-embed">
              <iframe
                width="560" height="315" src="https://www.youtube.com/embed/EEC1OfU_4_s?si=L6YqCa3S02O_hJlv" 
                title="YouTube video player" frameborder="0" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                referrerpolicy="strict-origin-when-cross-origin" 
                allowfullscreen>
              </iframe>
              </div>
            </>
          )}
          <div class="detail-actions">
            <a class="card-link" href="#projects">Back to projects ↑</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  #projects {
    background: linear-gradient(to bottom, var(--bg), #0a0d12, var(--bg));
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) * 1.5);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(243, 194, 7, 0.3);
    box-shadow: 0 12px 40px rgba(243, 194, 7, 0.07);
  }

  .card-thumb {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .card-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(255,255,255,0.015) 0px,
      rgba(255,255,255,0.015) 1px,
      transparent 1px,
      transparent 20px
    );
  }

  .card-thumb-label {
    font-size: 1.5rem;
    font-weight: 700;
    color: rgba(255,255,255,0.15);
    letter-spacing: -0.02em;
    font-family: var(--font-mono);
    z-index: 1;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .card-body p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    background: rgba(243, 194, 7, 0.1);
    border: 1px solid rgba(243, 194, 7, 0.2);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    transition: gap 0.2s;
    display: inline-block;
    margin-top: 0.25rem;
  }
  .card-link:hover {
    text-decoration: none;
    color: var(--accent-dim);
  }

  .project-details {
    margin-top: 3rem;
    display: grid;
    gap: 1rem;
  }

  .project-detail {
    scroll-margin-top: 6rem;
    background: rgba(22, 27, 36, 0.7);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) * 1.5);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-detail h3 {
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }

  .project-detail p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .detail-subtitle {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .detail-subtitle-text {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .video-embed {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }

  .video-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .video-embed video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .detail-actions {
    margin-top: 0.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
