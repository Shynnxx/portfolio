---
const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/Shynnxx',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
];
---

<section id="contact">
  <div class="container">
    <h2 class="section-title">Get in <span>Touch</span></h2>
    <div class="section-divider"></div>

    <div class="contact-inner">
      <p class="intro">
        Have a project in mind, want to collaborate, or just want to talk games?
        Feel free to reach out — I'm always happy to connect.
      </p>

      <a class="email-btn" href="mailto:felixflh5@gmail.com">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        Send me a mail
      </a>

      <div class="socials">
        {socials.map((s) => (
          <a class="social-link" href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
            <Fragment set:html={s.icon} />
            <span>{s.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="container">
    <p>Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · © {new Date().getFullYear()} Shynn</p>
  </div>
</footer>

<style>
  #contact {
    background: linear-gradient(to bottom, var(--bg), #0a0d12);
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
    max-width: 560px;
  }

  .intro {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.75;
  }

  .email-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--bg-card);
    border: 1.5px solid var(--border);
    color: var(--text);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-size: 1rem;
    font-weight: 600;
    transition: border-color 0.2s, color 0.2s;
  }
  .email-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  .socials {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: color 0.2s, border-color 0.2s;
  }
  .social-link:hover {
    color: var(--accent);
    border-color: rgba(243, 194, 7, 0.3);
    text-decoration: none;
  }

  footer {
    background: #0a0d12;
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    text-align: center;
  }

  footer p {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
