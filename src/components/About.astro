---
const skills = [
  { category: 'Engines', items: ['Unreal Engine 5'] },
  { category: 'Languages', items: ['C++', 'HTML'] },
  { category: 'Specialties', items: ['Technical Design', 'Gameplay Programming', 'Blueprints', 'Communication'] },
  { category: 'Tools', items: ['Git', 'Perforce', 'Source Tree', 'GitHub Copilot', 'VS Code', 'Visual Studio', 'JetBrains Rider', 'JIRA'] },
];
---

<section id="about">
  <div class="container">
    <h2 class="section-title">About <span>Me</span></h2>
    <div class="section-divider"></div>

    <div class="about-grid">
      <div class="bio">
        <p>
          I'm Felix, aka Shynn, a competitive MOBA player turned developer with a passion for
          building and designing games that are fun.
          It is probably very hard to find a game on Steam that I cannot tell you anything about,
          since I enjoy almost every genre, ranging from indie to AAA.

        </p>
        <p>
          I've been working on games full-time since May 2022, with only a short break in 2025
          when I finished my Bachelor's degree in Business Informatics.
        </p>
        <p>
          With growing experience, a problem-solving attitude, and AI utilization, I feel
          confident tackling almost any challenge.
        </p>
      </div>

      <div class="skills">
        {skills.map((group) => (
          <div class="skill-group">
            <h3>{group.category}</h3>
            <ul>
              {group.items.map((skill) => (
                <li>
                  <span class="dot" aria-hidden="true"></span>
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #about {
    background: var(--bg);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 700px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .bio p {
    color: var(--text-muted);
    line-height: 1.75;
    font-size: 0.97rem;
  }

  .skills {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .skill-group h3 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }

  .skill-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .skill-group li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
</style>
